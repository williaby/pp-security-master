# Example environment variables for Security Master

# Database Configuration (PostgreSQL 17)
# Option 1: Full connection string (takes priority if set)
# ⚠️  WARNING: python-dotenv has parsing issues with # characters in passwords
# If password contains #, the value will be truncated at that character
# Recommended: Use individual components below instead for complex passwords
DATABASE_URL=postgresql://username:password@192.168.1.16:5436/pp_master

# Option 2: Individual components (RECOMMENDED for passwords with special characters)
POSTGRES_HOST=192.168.1.16  # Unraid server IP address
POSTGRES_PORT=5436          # External port mapped to PostgreSQL container
POSTGRES_DB=pp_master       # Database name (must match container POSTGRES_DB)
POSTGRES_USER=username      # Database user (must match container POSTGRES_USER)
POSTGRES_PASSWORD=password  # Database password (must match container POSTGRES_PASSWORD)
# Note: If password contains #, quotes won't help due to dotenv limitations
# The connection test includes a workaround for known password patterns

# API Configuration
OPENFIGI_API_KEY=your_openfigi_api_key_here
OPENFIGI_BASE_URL=https://api.openfigi.com/v3

# Portfolio Performance API Keys
Alpha_Vantage_API=your_alpha_vantage_api_key_here
TwelveDate_API=your_twelve_data_api_key_here
Finnhub_API=your_finnhub_api_key_here
EODHD_API=your_eodhd_api_key_here

# Application Settings
LOG_LEVEL=INFO
DATA_ROOT_PATH=./data
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Rate Limiting
API_RATE_LIMIT_PER_MINUTE=10
API_BACKOFF_FACTOR=2

# CI/CD Configuration
CODECOV_TOKEN=your_codecov_token_here
